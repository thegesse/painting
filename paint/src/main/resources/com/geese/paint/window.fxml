<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.canvas.Canvas?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.geese.paint.Controller.TempController"
            prefHeight="400.0" prefWidth="600.0">

    <HBox AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <AnchorPane minWidth="120" style="-fx-background-color: #444444;">
            <children>
                <VBox spacing="15" AnchorPane.topAnchor="15" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">
                    <Label text="PALETTE" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 14;" />

                    <TilePane prefColumns="2" hgap="8" vgap="8">
                        <Button fx:id="blueButton" text="Blue" prefWidth="50" />
                        <Button fx:id="greenButton" text="Green" prefWidth="50" />
                        <Button fx:id="redButton" text="Red" prefWidth="50" />
                        <Button fx:id="purpleButton" text="Purple" prefWidth="50" />
                        <Button fx:id="yellowButton" text="Yellow" prefWidth="50" />
                        <Button fx:id="blackButton" text="Black" prefWidth="50" />
                        <Button fx:id="whiteButton" text="White" prefWidth="50" style="-fx-border-color: #888888;" />
                    </TilePane>

                    <Separator opacity="0.3" />
                    <Label text="TOOLS" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 14;" />
                    <TilePane prefColumns="2" hgap="8" vgap="8">
                        <Button fx:id="penButton" text="Pen" onAction="#selectPen" prefWidth="50" />
                        <Button fx:id="rectButton" text="Square" onAction="#selectRectangle" prefWidth="50" />
                        <Button fx:id="circleButton" text="Circle" onAction="#selectCircle" prefWidth="50" />
                        <Button fx:id="bucketButton" text="Bucket" onAction="#selectBucket" prefWidth="50" />
                        <Button fx:id="eraserButton" text="Eraser" onAction="#selectEraser" prefWidth="50" />
                    </TilePane>

                    <Separator opacity="0.3" />
                    <Label text="SETTINGS" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 14;" />
                    <TilePane prefColumns="1" vgap="10">
                        <VBox spacing="5" alignment="CENTER_LEFT">
                            <HBox spacing="10">
                                <Label text="Size:" textFill="WHITE" />
                                <Label fx:id="sizeLabel" text="5.0" textFill="CYAN" />
                            </HBox>
                            <Slider fx:id="sizeSlider" min="1" max="100" value="5"
                                    showTickMarks="true" majorTickUnit="25"
                                    prefWidth="150" />
                        </VBox>

                        <Button text="Clear Canvas" onAction="#clearCanvas"
                                style="-fx-background-color: #ff4444; -fx-text-fill: white;"
                                prefWidth="150" />
                    </TilePane>
                    <Separator opacity="0.3" />
                    <Button text="Save as PNG" onAction="#saveImage"
                            style="-fx-background-color: #4CAF50; -fx-text-fill: white;"
                            prefWidth="150" />
                    <Label fx:id="statusLabel" text="X: 0 | Y: 0" textFill="#cccccc" style="-fx-font-family: 'Monospaced';" />
                </VBox>
            </children>
        </AnchorPane>

        <Pane fx:id="canvasContainer" HBox.hgrow="ALWAYS" style="-fx-background-color: white;">
            <children>
                <Canvas fx:id="canvas" width="500" height="480" />
            </children>
        </Pane>
    </HBox>
</AnchorPane>